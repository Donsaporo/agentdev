[Unit]
Description=Obzide Sales Agent
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/obzide-sales
ExecStart=/usr/bin/node dist/main.js
Restart=always
RestartSec=5
StartLimitBurst=10
StartLimitIntervalSec=300
Environment=NODE_ENV=production
EnvironmentFile=/opt/obzide-sales/.env
StandardOutput=journal
StandardError=journal
SyslogIdentifier=obzide-sales
MemoryMax=512M

[Install]
WantedBy=multi-user.target
